# =============================================================================
# Adversary-in-a-Box — Environment Configuration Template
# Copy this file to .env and fill in your values before running docker compose
#
# Phase 0 — Per-student isolation:
#   STUDENT_ID, COMPOSE_PROJECT_NAME, LAB_NET_PREFIX, QUARANTINE_NET_PREFIX,
#   and the *_PORT variables let multiple students run isolated lab stacks
#   side-by-side on the same host.
#
#   Quickest path: `scripts/lab/student-env.sh jdoe > .env` will generate a
#   complete, conflict-free .env from a student id.
# =============================================================================

# --- Per-Student Isolation (Phase 0) ---
# Short, lowercase, alphanumeric. Used as a slug everywhere.
STUDENT_ID=default
# The Compose project name prefixes all container and network names.
# Conventionally: aib-<STUDENT_ID>
COMPOSE_PROJECT_NAME=adversary-in-a-box
# /24 subnets for the lab network and the quarantine network. Each student
# should get a unique pair to avoid IPAM collisions on the same host.
LAB_NET_PREFIX=172.20.0
QUARANTINE_NET_PREFIX=172.20.1

# --- Compose Profiles ---
# audit-4 G3b: IR is OPT-IN. The blue-team dashboard gets the Docker socket
# + NET_ADMIN and ships an unauthenticated POST /api/run-playbook, so it is
# NOT started by default -- matching the security note in the README. A bare
# `docker compose up` brings up the lab WITHOUT that host-privileged
# container. Opt in explicitly when you want incident response:
#   COMPOSE_PROFILES=ir docker compose up -d
# Add the PKI lab (OQ-4) too: COMPOSE_PROFILES=ir,pki
COMPOSE_PROFILES=

# --- Host Port Bindings ---
# Defaults match single-student usage. For multi-student, offset per student.
BLUE_TEAM_PORT=5000
SCOREBOARD_PORT=5002
KIBANA_PORT=5601
ELASTICSEARCH_PORT=9200
PKI_NGINX_PORT=8443

# --- Suricata sensor interface (instructor-side; host network) ---
SURICATA_IFACE=eth0

# --- Target Environment ---
# Hostnames are preferred over IPs so per-student LAB_NET_PREFIX changes
# don't break anything. The DNS resolves inside each Compose project.
TARGET_WEB_URL=http://victim-web
TARGET_DB_HOST=victim-db
TARGET_MAIL_HOST=victim-mail

# --- Database Credentials (intentionally weak for lab purposes) ---
DB_ROOT_PASS=root
DB_NAME=labdb
DB_USER=admin
DB_PASS=password123

# --- ELK Stack ---
ELASTICSEARCH_URL=http://elasticsearch:9200
KIBANA_URL=http://kibana:5601

# --- Flask Applications ---
# CHANGE THIS in production or any shared environment
FLASK_SECRET_KEY=adversary-in-a-box-lab-secret-key-change-me

# --- Logging ---
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- SIEM ---
SIEM_HOST=elasticsearch

# --- Red Team Config ---
# Campaign timeout in seconds
CAMPAIGN_TIMEOUT=300
# Enable verbose attack logging
VERBOSE_ATTACK_LOG=true

# --- Scoring Thresholds (OQ-5 / ADR 0001) ---
# MTTD = Mean Time to Detect (attack event -> SIEM alert).
# Gold/Silver/Bronze tier ceilings, in seconds. Anything above MTTD_BRONZE_S is a Miss.
MTTD_GOLD_S=120
MTTD_SILVER_S=300
MTTD_BRONZE_S=600

# MTTA = Mean Time to Acknowledge (alert -> playbook complete), in seconds.
MTTA_GOLD_S=300
MTTA_SILVER_S=900
MTTA_BRONZE_S=1800

# Per-campaign point values and bonuses/penalties.
POINTS_PER_DETECTION=10
POINTS_PER_RESPONSE=10
FALSE_POSITIVE_PENALTY=5
EVIDENCE_BONUS=10
PLAYBOOK_CLEAN_BONUS=5
UNDETECTED_BONUS_RED=15

# Final blue-team score = DETECTION_WEIGHT * detection + RESPONSE_WEIGHT * response.
DETECTION_WEIGHT=0.5
RESPONSE_WEIGHT=0.5

# --- Phase 0 Safety / Preflight ---
# Domains the preflight check refuses to start the lab if they resolve from
# the host. Comma-separated. Add your university domain here.
SAFE_MODE_DOMAINS=uiwtx.edu,my.uiwtx.edu
# AD ports that must NOT be reachable on SAFE_MODE_DOMAINS hosts.
SAFE_MODE_AD_PORTS=88,389,445,636,3268,3269
