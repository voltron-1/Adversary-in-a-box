# =============================================================================
# Adversary-in-a-Box — Environment Configuration Template
# Copy this file to .env and fill in your values before running docker compose
# =============================================================================

# --- Target Environment ---
TARGET_WEB_URL=http://172.20.0.30
TARGET_DB_HOST=172.20.0.31
TARGET_MAIL_HOST=172.20.0.32

# --- Database Credentials (intentionally weak for lab purposes) ---
DB_ROOT_PASS=root
DB_NAME=labdb
DB_USER=admin
DB_PASS=password123

# --- ELK Stack ---
ELASTICSEARCH_URL=http://172.20.0.50:9200
KIBANA_URL=http://172.20.0.52:5601

# --- Flask Applications ---
# CHANGE THIS in production or any shared environment
FLASK_SECRET_KEY=adversary-in-a-box-lab-secret-key-change-me

# --- Logging ---
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- SIEM ---
SIEM_HOST=172.20.0.50

# --- Red Team Config ---
# Campaign timeout in seconds
CAMPAIGN_TIMEOUT=300
# Enable verbose attack logging
VERBOSE_ATTACK_LOG=true

# --- Scoring Thresholds (OQ-5 / ADR 0001) ---
# MTTD = Mean Time to Detect (attack event -> SIEM alert).
# Gold/Silver/Bronze tier ceilings, in seconds. Anything above MTTD_BRONZE_S is a Miss.
MTTD_GOLD_S=120
MTTD_SILVER_S=300
MTTD_BRONZE_S=600

# MTTA = Mean Time to Acknowledge (alert -> playbook complete), in seconds.
MTTA_GOLD_S=300
MTTA_SILVER_S=900
MTTA_BRONZE_S=1800

# Per-campaign point values and bonuses/penalties.
POINTS_PER_DETECTION=10
POINTS_PER_RESPONSE=10
FALSE_POSITIVE_PENALTY=5
EVIDENCE_BONUS=10
PLAYBOOK_CLEAN_BONUS=5
UNDETECTED_BONUS_RED=15

# Final blue-team score = DETECTION_WEIGHT * detection + RESPONSE_WEIGHT * response.
DETECTION_WEIGHT=0.5
RESPONSE_WEIGHT=0.5
